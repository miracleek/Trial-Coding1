rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/appUsers/$(request.auth.uid)).data.role == 'admin';
    }

    // Shared categories — readable by all authenticated users, writable only by admin
    match /sharedCategories/{catId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Per-user data — only the owner can read/write
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // App users — authenticated users can read their own doc; admin can read all
    match /appUsers/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }
  }
}
